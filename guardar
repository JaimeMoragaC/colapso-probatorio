#!/usr/bin/env bash
# guardar — registra los cambios del paper en git con un solo comando.
#
#   Uso:
#     ./guardar "mensaje del cambio"          add + commit (solo archivos ya trackeados)
#     ./guardar "mensaje del cambio" --ts     además sella con OpenTimestamps (si 'ots' existe)
#     ./guardar --help
#
# NO rehace nada: cada ejecución crea UN commit nuevo con lo que cambiaste.
# El historial anterior queda intacto. Solo toca archivos ya versionados;
# los archivos nuevos NO se incluyen salvo que los añadas tú con 'git add'.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

DO_TS=0
MSG=""
for arg in "$@"; do
  case "$arg" in
    --ts)      DO_TS=1 ;;
    -h|--help) awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0"; exit 0 ;;
    *)         if [ -z "$MSG" ]; then MSG="$arg"; else MSG="$MSG $arg"; fi ;;
  esac
done

if [ -z "$MSG" ]; then
  echo "Uso: ./guardar \"mensaje del cambio\" [--ts]" >&2
  exit 1
fi

cd "$SCRIPT_DIR"

# Estagear SOLO cambios de archivos ya trackeados (no barre archivos nuevos/basura).
git add -u -- .

# Sello de tiempo opcional (prueba de existencia anclada a Bitcoin).
if [ "$DO_TS" -eq 1 ]; then
  # Resolver el binario 'ots': PATH primero, luego el venv conocido, luego OTS_BIN.
  OTS_BIN="${OTS_BIN:-}"
  if [ -z "$OTS_BIN" ]; then
    if command -v ots >/dev/null 2>&1; then
      OTS_BIN="ots"
    elif [ -x "/home/jaime/Descargas/antigravity/.venv/bin/ots" ]; then
      OTS_BIN="/home/jaime/Descargas/antigravity/.venv/bin/ots"
    fi
  fi

  if [ -n "$OTS_BIN" ]; then
    for f in PAPER_v3_trabajo.md PAPER_v3_Formato_Institucional.pdf; do
      [ -f "$f" ] || continue
      # 'ots stamp' se NIEGA a sobrescribir un .ots existente (Errno 17: File exists).
      # Para re-sellar el contenido nuevo: respaldamos el proof anterior en .ots.bak
      # (gitignored) y lo retiramos; si el sello falla, lo restauramos.
      if [ -f "$f.ots" ]; then
        cp -f -- "$f.ots" "$f.ots.bak"
        rm -f -- "$f.ots"
      fi
      if "$OTS_BIN" stamp "$f"; then
        if [ -f "$f.ots" ]; then git add -- "$f.ots"; fi
      else
        echo "aviso: no se pudo sellar $f (¿calendarios inaccesibles?)" >&2
        # El nuevo sello no se creó: restaurar el proof anterior desde el respaldo.
        if [ ! -f "$f.ots" ] && [ -f "$f.ots.bak" ]; then
          cp -f -- "$f.ots.bak" "$f.ots"
          echo "aviso: restaurado $f.ots desde el respaldo .bak" >&2
        fi
      fi
    done
  else
    echo "aviso: 'ots' no está en PATH ni en el venv; se omite el sello." >&2
    echo "       (instala con 'pip install opentimestamps-client', o exporta OTS_BIN=/ruta/a/ots)" >&2
  fi
fi

# ¿Hay algo staged?
if git diff --cached --quiet; then
  echo "No hay cambios en el paper para guardar."
  untracked="$(git ls-files --others --exclude-standard -- . | head)"
  if [ -n "$untracked" ]; then
    echo "(Archivos nuevos NO incluidos; añádelos con 'git add' si los quieres versionar:)"
    echo "$untracked"
  fi
  exit 0
fi

echo "── se va a guardar:"
git diff --cached --stat
echo

git commit -q -m "$MSG"
echo "✔ guardado en el commit $(git rev-parse --short HEAD)  —  $MSG"
